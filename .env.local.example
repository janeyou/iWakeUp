# Anthropic API key for the daily ingestion job (claude-opus-4-7 + web_search tool)
ANTHROPIC_API_KEY=sk-ant-...

# Random secret used to authenticate the Vercel Cron callback
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Vercel Postgres — Vercel injects POSTGRES_URL automatically in production.
# For local dev, paste the value from `vercel env pull` or the dashboard.
POSTGRES_URL=

# X API v2 (developer.x.com) bearer token, free tier ~100 posts/month
X_BEARER_TOKEN=

# Resend (resend.com), for newsletter signup + weekly digest emails
RESEND_API_KEY=
# The "From" address used in outbound emails. Must be a verified domain in Resend.
# For local testing without a verified domain, leave RESEND_API_KEY blank: emails go to console only.
RESEND_FROM=iWakeUp <hello@radar.pmclaws.com>

# Public base URL for unsubscribe + confirm links in emails
NEXT_PUBLIC_SITE_URL=https://radar.pmclaws.com
